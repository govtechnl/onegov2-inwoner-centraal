{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/govtechnl/onegov2-inwoner-centraal/data/schemas/03-rechten-partner.schema.json",
  "title": "Rights of the surviving partner",
  "description": "Zero or more records per surviving partner.",
  "type": "object",
  "required": ["id", "synthetic", "bron", "bsn_partner", "organisatie", "categorie", "omschrijving", "voorwaarden", "status"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^urn:recht:test:[0-9a-f-]{36}$" },
    "synthetic": { "const": true },
    "bron": { "const": "onegov2-inwoner-centraal-generator" },
    "bsn_partner": { "type": "string", "pattern": "^[0-9]{9}$" },
    "organisatie": {
      "enum": [
        "Gemeente", "SVB", "CAK", "RDW", "Waterschap", "Belastingdienst",
        "Toeslagen", "RVO", "CJIB", "UWV", "DUO", "KVK"
      ]
    },
    "categorie": {
      "enum": [
        "anw",
        "nabestaandenpensioen",
        "toeslag_herberekening",
        "bijstand",
        "inkomensondersteuning",
        "overig"
      ]
    },
    "omschrijving": { "type": "string", "minLength": 1 },
    "geschat_maandbedrag": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["bedrag", "valuta"],
          "additionalProperties": false,
          "properties": {
            "bedrag": { "type": "string", "pattern": "^-?[0-9]+\\.[0-9]{2}$" },
            "valuta": { "const": "EUR" }
          }
        }
      ]
    },
    "voorwaarden": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "status": { "enum": ["mogelijk_recht", "toegekend", "afgewezen", "aanvraag_open"] }
  }
}
