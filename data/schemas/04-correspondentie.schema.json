{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/govtechnl/onegov2-inwoner-centraal/data/schemas/04-correspondentie.schema.json",
  "title": "Correspondence stream — simulated letter flow per organisation",
  "description": "Many records per deceased person — typically 30-80.",
  "type": "object",
  "required": [
    "id", "synthetic", "bron", "bsn_overledene", "organisatie", "brief_code",
    "type", "verzonden_op", "dagen_na_overlijden", "aanhef", "geadresseerde",
    "adres", "actie_vereist"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^urn:brief:test:[0-9a-f-]{36}$" },
    "synthetic": { "const": true },
    "bron": { "const": "onegov2-inwoner-centraal-generator" },
    "bsn_overledene": { "type": "string", "pattern": "^[0-9]{9}$" },
    "organisatie": {
      "enum": [
        "Gemeente", "SVB", "CAK", "RDW", "Waterschap", "Belastingdienst",
        "Toeslagen", "RVO", "CJIB", "UWV", "DUO", "KVK"
      ]
    },
    "brief_code": {
      "type": "string",
      "description": "Stable key from data-generation/reference/brieven-catalogus.yaml",
      "minLength": 1
    },
    "type": {
      "enum": [
        "informatiebrief",
        "actiebrief",
        "factuur",
        "aanmaning",
        "condoleance",
        "beschikking",
        "terugvordering"
      ]
    },
    "verzonden_op": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "dagen_na_overlijden": { "type": "integer", "minimum": 0 },
    "aanhef": { "type": "string", "minLength": 1 },
    "geadresseerde": { "enum": ["overledene", "erven", "partner", "contactpersoon"] },
    "adres": {
      "type": "object",
      "required": ["straat", "huisnummer", "postcode", "woonplaats"],
      "additionalProperties": false,
      "properties": {
        "straat": { "type": "string", "minLength": 1 },
        "huisnummer": { "type": "string", "minLength": 1 },
        "postcode": { "type": "string", "pattern": "^[0-9]{4}\\s?[A-Z]{2}$" },
        "woonplaats": { "type": "string", "minLength": 1 },
        "verzorgingstehuis": { "type": "boolean", "default": false }
      }
    },
    "actie_vereist": { "type": "boolean" },
    "actie_omschrijving": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "wettelijke_reactietermijn_dagen": {
      "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }]
    }
  }
}
