{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/govtechnl/onegov2-inwoner-centraal/data/schemas/02-verplichtingen.schema.json",
  "title": "Outstanding obligations of the deceased",
  "description": "Zero or more records per deceased person.",
  "type": "object",
  "required": ["id", "synthetic", "bron", "bsn_overledene", "organisatie", "categorie", "omschrijving", "status"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^urn:verplichting:test:[0-9a-f-]{36}$" },
    "synthetic": { "const": true },
    "bron": { "const": "onegov2-inwoner-centraal-generator" },
    "bsn_overledene": { "type": "string", "pattern": "^[0-9]{9}$" },
    "organisatie": { "$ref": "#/$defs/organisatie" },
    "categorie": {
      "enum": [
        "toeslag",
        "aanslag_ib",
        "erfbelasting",
        "wmo",
        "pensioen",
        "aow",
        "wlz",
        "lokaal_belasting",
        "boete",
        "overig"
      ]
    },
    "omschrijving": { "type": "string", "minLength": 1 },
    "bedrag": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/bedrag" }] },
    "peildatum": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/date" }] },
    "vervaldatum": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/date" }] },
    "status": { "enum": ["open", "voldaan", "kwijtgescholden", "in_behandeling"] },
    "wettelijke_termijn_dagen": { "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }] }
  },
  "$defs": {
    "organisatie": {
      "enum": [
        "Gemeente", "SVB", "CAK", "RDW", "Waterschap", "Belastingdienst",
        "Toeslagen", "RVO", "CJIB", "UWV", "DUO", "KVK"
      ]
    },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "bedrag": {
      "type": "object",
      "required": ["bedrag", "valuta"],
      "additionalProperties": false,
      "properties": {
        "bedrag": { "type": "string", "pattern": "^-?[0-9]+\\.[0-9]{2}$" },
        "valuta": { "const": "EUR" }
      }
    }
  }
}
